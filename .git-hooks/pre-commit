#!/usr/bin/env bash
# Pre-commit hook: ECS auto-fix on staged PHP files + Pest arch check.
#
# Activate:
#   git config core.hooksPath .git-hooks
#   chmod +x .git-hooks/pre-commit

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Get staged PHP files (added/copied/modified, not deleted)
STAGED_PHP=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.php$' || true)

if [ -n "$STAGED_PHP" ]; then
    echo -e "${YELLOW}► ECS auto-fix on staged PHP files...${NC}"
    if [ -x ./vendor/bin/ecs ]; then
        echo "$STAGED_PHP" | xargs ./vendor/bin/ecs check --fix
        # Re-stage files that ECS modified
        echo "$STAGED_PHP" | xargs git add
    elif command -v sail >/dev/null 2>&1 || [ -x ./vendor/bin/sail ]; then
        echo "$STAGED_PHP" | xargs ./vendor/bin/sail bin ecs check --fix
        echo "$STAGED_PHP" | xargs git add
    else
        echo -e "${YELLOW}⚠ ECS not found — skipping style fix${NC}" >&2
    fi
fi

echo -e "${YELLOW}► Architecture tests (Pest --arch)...${NC}"
if [ -x ./vendor/bin/pest ]; then
    if ! ./vendor/bin/pest --arch --colors=always; then
        echo -e "${RED}✘ Architecture violations — fix before committing${NC}" >&2
        exit 1
    fi
elif [ -x ./vendor/bin/sail ]; then
    if ! ./vendor/bin/sail bin pest --arch --colors=always; then
        echo -e "${RED}✘ Architecture violations — fix before committing${NC}" >&2
        exit 1
    fi
else
    echo -e "${YELLOW}⚠ Pest not found — skipping arch check${NC}" >&2
fi

echo -e "${GREEN}✔ Pre-commit checks passed${NC}"
exit 0
