{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(composer:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(./vendor/bin/sail:*)",
      "Bash(./vendor/bin/pest:*)",
      "Bash(./vendor/bin/phpunit:*)",
      "Bash(./vendor/bin/phpstan:*)",
      "Bash(./vendor/bin/ecs:*)",
      "Bash(./vendor/bin/rector:*)",
      "Bash(php:*)",
      "Bash(php artisan:*)",
      "Bash(php -l:*)",
      "Bash(php -r:*)",

      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git fetch:*)",
      "Bash(git stash:*)",
      "Bash(git branch:*)",
      "Bash(git config core.hooksPath:*)",
      "Bash(git add:*)",

      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(jq:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(chmod:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",

      "WebSearch",
      "WebFetch(domain:laravel.com)",
      "WebFetch(domain:php.net)",
      "WebFetch(domain:pestphp.com)",
      "WebFetch(domain:phpstan.org)",
      "WebFetch(domain:vuejs.org)",
      "WebFetch(domain:pinia.vuejs.org)",
      "WebFetch(domain:vitest.dev)",
      "WebFetch(domain:playwright.dev)",
      "WebFetch(domain:refactoring.guru)",
      "WebFetch(domain:github.com)",

      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "mcp__playwright",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_click",
      "mcp__playwright__browser_screenshot",
      "mcp__playwright__browser_get_text",
      "mcp__mysql__mysql_query",
      "mcp__laravel-boost"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(git branch -D:*)",
      "Bash(git rebase --interactive:*)",
      "Bash(rm -rf /:*)",
      "Bash(curl:*api*)",
      "Bash(wget:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/no-laravel-helpers.sh", "timeout": 10 },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/php-strict-types.sh", "timeout": 10 },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/php-no-inline-comments.sh", "timeout": 10 },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/php-no-phpdoc-descriptions.sh", "timeout": 10 },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/php-method-length.sh", "timeout": 10 },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/php-class-length.sh", "timeout": 10 },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/php-too-many-params.sh", "timeout": 10 },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/php-magic-numbers.sh", "timeout": 10 },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/php-nested-if.sh", "timeout": 10 }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/doc-reminder.sh", "timeout": 15 }
        ]
      }
    ]
  },
  "enabledMcpjsonServers": [
    "context7",
    "playwright",
    "mysql",
    "laravel-boost"
  ]
}
